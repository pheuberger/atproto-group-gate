{
  "lexicon": 1,
  "id": "app.certified.group.member.remove",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Remove a member from the group. Requires admin or owner role.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["memberDid"],
          "properties": {
            "memberDid": { "type": "string", "format": "did" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {}
        }
      },
      "errors": [
        { "name": "Unauthorized" },
        { "name": "Forbidden" },
        { "name": "MemberNotFound" },
        { "name": "CannotRemoveOwner" }
      ]
    }
  }
}
