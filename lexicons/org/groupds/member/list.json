{
  "lexicon": 1,
  "id": "org.groupds.member.list",
  "defs": {
    "main": {
      "type": "query",
      "description": "List members of the group. Requires membership.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": { "type": "integer", "minimum": 1, "maximum": 100, "default": 50 },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["members"],
          "properties": {
            "cursor": { "type": "string" },
            "members": {
              "type": "array",
              "items": { "type": "ref", "ref": "#member" }
            }
          }
        }
      },
      "errors": [
        { "name": "Unauthorized" }
      ]
    },
    "member": {
      "type": "object",
      "required": ["did", "role", "addedAt"],
      "properties": {
        "did": { "type": "string", "format": "did" },
        "role": { "type": "string", "knownValues": ["member", "admin", "owner"] },
        "addedBy": { "type": "string", "format": "did" },
        "addedAt": { "type": "string", "format": "datetime" }
      }
    }
  }
}
